# ============================================================
# TaxSentry UAE — Environment Variables
# Copy to .env.local and fill in real values
# NEVER commit .env.local to git
# ============================================================

# === DATABASE (Supabase Postgres) ===
# Use Transaction mode (port 6543) for app — handles connection pooling
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Use Session mode (port 5432) for migrations only
DATABASE_URL_UNPOOLED="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# === SUPABASE (Storage + DB) ===
SUPABASE_URL="https://[project-ref].supabase.co"
# Public anon key — safe for client if needed, but we only use server-side
SUPABASE_ANON_KEY="eyJ..."
# Service role key — SERVER ONLY, never expose to browser
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
SUPABASE_STORAGE_BUCKET="qfzp-documents"

# === AUTH (Custom JWT + argon2id) ===
# Must be at least 32 random characters — used to sign JWT access tokens
JWT_SECRET="change-me-in-production-use-openssl-rand-hex-32"
# Short-lived access token TTL (15 minutes is the recommended maximum)
JWT_EXPIRY="15m"

# === EMAIL (Resend — free tier: 3,000 emails/month) ===
RESEND_API_KEY="re_..."
EMAIL_FROM="alerts@taxsentry.ae"

# === DODO PAYMENTS (Merchant of Record — replaces Stripe) ===
# Get these from https://dashboard.dodopayments.com
# DODO_ENV: "test" for sandbox, "live" for production
DODO_ENV="test"
DODO_API_KEY="..."
# Webhook secret from the Dodo dashboard → Webhooks → your endpoint → Signing secret
DODO_WEBHOOK_SECRET="whsec_..."

# Product IDs — create these in Dodo dashboard under Products
# Each maps to a subscription plan with the correct price + billing interval
# Prices are charged in USD (AED/3.6725 fixed peg), displayed in AED in the UI
DODO_PRODUCT_STARTER_MONTHLY="prd_..."    # ~$82 USD (AED 299/month)
DODO_PRODUCT_STARTER_YEARLY="prd_..."     # ~$815 USD (AED 2,990/year)
DODO_PRODUCT_GROWTH_MONTHLY="prd_..."     # ~$218 USD (AED 799/month)
DODO_PRODUCT_GROWTH_YEARLY="prd_..."      # ~$2,176 USD (AED 7,990/year)
# ENTERPRISE is handled manually / custom contract — no product ID needed

# === APP ===
NODE_ENV="development"
API_PORT=3001
# On Render/Railway: set API_URL to your service URL, e.g. https://api.taxsentry.ae
API_URL="http://localhost:3001"
# On Vercel: set WEB_URL to your Vercel domain — used in password reset email links
WEB_URL="http://localhost:3000"

# === SENTRY (optional — free tier available) ===
SENTRY_DSN=""

# === FEATURE FLAGS ===
ENABLE_ZOHO_SYNC="false"
ENABLE_XERO_SYNC="false"
ENABLE_WHATSAPP_ALERTS="false"
